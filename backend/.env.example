# Токен доступа T-Invest API (readonly достаточно для просмотра портфеля)
# Получить: https://developer.tbank.ru/invest/intro/intro/
TINKOFF_TOKEN=your_token_here

# sandbox | prod
TINKOFF_MODE=prod

# Проверка SSL. false — если ошибка CERTIFICATE_VERIFY_FAILED (прокси/антивирус)
TINKOFF_SSL_VERIFY=true

# Альтернатива: путь к корневому сертификату организации
# TINKOFF_SSL_CA_FILE=C:\path\to\corp-ca.pem

# Прокси, если invest-public-api.tbank.ru недоступен напрямую
# TINKOFF_HTTPS_PROXY=http://127.0.0.1:8080

# AI-чат на странице портфеля (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Запасной провайдер (https://console.groq.com/keys)
GROQ_API_KEY=

# Опционально: модели по умолчанию
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# CHAT_MAX_OUTPUT_TOKENS=8192
